{
  "name": "skygit",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "homepage": "https://manaty.net/skygit",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:debug": "vite build --mode debug",
    "deploy": "npm run build:debug && gh-pages --dotfiles --branch gh-pages --dist dist",
    "test:e2e": "playwright test",
    "test:e2e:api": "PLAYWRIGHT_SKIP_WEB_SERVER=1 playwright test --project=api",
    "test:e2e:ui": "playwright test --project=ui",
    "test:e2e:deployed:api": "PLAYWRIGHT_SKIP_WEB_SERVER=1 PLAYWRIGHT_BASE_URL=https://manaty.net/skygit/ playwright test --project=api",
    "test:e2e:deployed:ui": "PLAYWRIGHT_SKIP_WEB_SERVER=1 PLAYWRIGHT_BASE_URL=https://manaty.net/skygit/ playwright test --project=ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "gh-pages": "^6.3.0",
    "svelte": "^5.20.2",
    "vite": "^6.3.5",
    "vite-plugin-pwa": "^1.0.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.17",
    "lucide-svelte": "^0.485.0",
    "peerjs": "^1.5.4",
    "tailwindcss": "^4.0.17",
    "uuid": "^14.0.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5"
  }
}
